NEXT_PUBLIC_SITE_URL=https://example.com

# مصدر بيانات الكتالوج وCMS الوحيد وقت التشغيل (استخدم رابط Pooler في Neon)
DATABASE_URL=postgresql://user:password@pooler-host/database?sslmode=require

# اتصال مباشر لـ Prisma Migrations فقط؛ اتركه مساوياً لـ DATABASE_URL محلياً عند عدم وجود Pooler
DIRECT_URL=postgresql://user:password@direct-host/database?sslmode=require

# دخول لوحة الإدارة. AUTH_SECRET يوقّع الجلسات ويشفّر مفاتيح مزودات الدفع الديناميكية.
# تغييره لاحقاً يبطل الجلسات ويمنع فك المفاتيح المحفوظة سابقاً.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=[ضع كلمة مرور قوية من 12 حرفاً على الأقل]
AUTH_SECRET=[ضع قيمة عشوائية بطول 32 حرفاً على الأقل]

# تحقق بريد العملاء واستعادة كلمة المرور عبر Resend.
# وثّق eliteworldsa.com لدى المزود قبل استخدام عنوان المرسل في الإنتاج.
RESEND_API_KEY=
EMAIL_FROM=ELITE WORLD <no-reply@eliteworldsa.com>

# Vercel Blob يضيف BLOB_STORE_ID ومصادقة OIDC تلقائياً عند ربط المخزن بالمشروع.
# لا تضع مفتاحاً حقيقياً هنا. يبقى التخزين المحلي فعالاً عند التطوير بدونه.

# مساعد SEO بالذكاء الاصطناعي اختياري بالكامل
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
